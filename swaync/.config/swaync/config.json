{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "ignore-gtk-theme": true,
  "cssPriority": "application",

  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "layer-shell": true,

  "control-center-positionX": "right",
  "control-center-positionY": "top",
  "control-center-layer": "top",
  "control-center-exclusive-zone": true,
  "control-center-margin-top": 42,
  "control-center-margin-right": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-left": 0,
  "control-center-width": 420,
  "control-center-height": 640,

  "notification-2fa-action": true,
  "notification-window-width": 420,
  "timeout": 6,
  "timeout-low": 3,
  "timeout-critical": 0,
  "fit-to-screen": false,

  "widgets": [
    "title",
    "dnd",
    "buttons-grid",
    "volume",
    "notifications"
  ],

  "widget-config": {
    "notifications": {},

    "title": {
      "text": "Notification Center",
      "clear-all-button": true,
      "button-text": "Clear"
    },

    "dnd": {
      "text": "Do Not Disturb"
    },

    "buttons-grid": {
      "buttons-per-row": 4,
      "actions": [
        {
          "label": "󰂯",
          "command": "sh -lc 'exec blueman-manager'"
        },
        {
          "label": "󰖩",
          "command": "sh -lc 'exec nm-connection-editor'"
        },
        {
          "label": "󰓃",
          "command": "sh -lc 'exec pavucontrol'"
        },
        {
          "label": "󰍬",
          "command": "sh -lc 'exec pavucontrol'"
        }
      ]
    },

    "volume": {
      "label": "󰕾",
      "show-per-app": false,
      "show-per-app-icon": false,
      "show-per-app-label": false
    }
  }
}
